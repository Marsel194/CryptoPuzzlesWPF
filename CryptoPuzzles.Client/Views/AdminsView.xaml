<UserControl x:Class="CryptoPuzzles.Client.Views.AdminsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Client.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Client.Helpers">
    <controls:EntityListControl 
        Title="Администраторы"
        BackCommand="{Binding BackCommand}"
        AddCommand="{Binding AddCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        SaveCommand="{Binding SaveCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="True"
        AddPanelTitle="Новый администратор"
        IsSaveButtonVisible="True"
        Foreground="{StaticResource MaterialDesignBody}">

        <controls:EntityListControl.AddPanelContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewItem.Login, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Логин" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="1" Text="{Binding NewItem.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Имя" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="2" Text="{Binding NewItem.LastName, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Фамилия" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="3" Text="{Binding NewItem.MiddleName, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Отчество" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <PasswordBox Grid.Column="4" helpers:PasswordHelper.Attach="True" 
                             helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Пароль" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <Button Grid.Column="5" Command="{Binding AddCommand}" Content="Добавить" 
                        Style="{StaticResource PrimaryButton}" Margin="4,0" Foreground="White"/>
            </Grid>
        </controls:EntityListControl.AddPanelContent>

        <controls:EntityListControl.MainContent>
            <StackPanel>
                <WrapPanel Margin="0,0,0,8">
                    <CheckBox Content="Показывать удалённых" IsChecked="{Binding ShowDeleted}" 
                              VerticalAlignment="Center" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding LoginFilter, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Логин" Width="120" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding NameFilter, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Имя/Фамилия" Width="150" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <DatePicker SelectedDate="{Binding MinCreatedAt}" 
                                materialDesign:HintAssist.Hint="С даты" Width="140" Margin="4" 
                                Style="{StaticResource MaterialDesignDatePicker}" Foreground="{StaticResource MaterialDesignBody}"/>
                    <DatePicker SelectedDate="{Binding MaxCreatedAt}" 
                                materialDesign:HintAssist.Hint="По дату" Width="140" Margin="4" 
                                Style="{StaticResource MaterialDesignDatePicker}" Foreground="{StaticResource MaterialDesignBody}"/>
                </WrapPanel>
                <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" Margin="10" 
                          AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                          materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                          Foreground="{StaticResource MaterialDesignBody}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="Auto" MinWidth="50"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="120"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="120"/>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="120"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="120"/>
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="Auto" MinWidth="150"/>
                        <DataGridCheckBoxColumn Header="Удален" Binding="{Binding IsDeleted, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="80"/>
                        <DataGridTextColumn Header="Дата удаления" Binding="{Binding DeletedAt, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="Auto" MinWidth="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>