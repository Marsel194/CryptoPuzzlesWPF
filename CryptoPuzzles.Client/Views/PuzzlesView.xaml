<UserControl x:Class="CryptoPuzzles.Client.Views.PuzzlesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Client.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Client.Helpers">
    <controls:EntityListControl 
        Title="Головоломки"
        BackCommand="{Binding BackCommand}"
        AddCommand="{Binding AddCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        SaveCommand="{Binding SaveCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="True"
        AddPanelTitle="Новая головоломка"
        IsSaveButtonVisible="True"
        Foreground="{StaticResource MaterialDesignBody}">

        <controls:EntityListControl.AddPanelContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewItem.Title, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Название" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="1" Text="{Binding NewItem.Content, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Содержание" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="2" Text="{Binding NewItem.Answer, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Ответ" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="3" Text="{Binding NewItem.MaxScore, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Макс. балл" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding Difficulties}" SelectedValuePath="Id" 
                          DisplayMemberPath="DifficultyName" SelectedValue="{Binding NewItem.DifficultyId}" 
                          helpers:ComboBoxBehavior.AutoOpenOnEdit="True" materialDesign:HintAssist.Hint="Сложность" Margin="4"
                          Foreground="{StaticResource MaterialDesignBody}"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding Methods}" SelectedValuePath="Id" 
                          DisplayMemberPath="Name" SelectedValue="{Binding NewItem.MethodId}" 
                          helpers:ComboBoxBehavior.AutoOpenOnEdit="True" materialDesign:HintAssist.Hint="Метод" Margin="4"
                          Foreground="{StaticResource MaterialDesignBody}"/>
                <CheckBox Grid.Column="6" Content="Обучение" IsChecked="{Binding NewItem.IsTraining}" 
                          VerticalAlignment="Center" Margin="4"
                          Foreground="{StaticResource MaterialDesignBody}"/>
                <TextBox Grid.Column="7" Text="{Binding NewItem.TutorialOrder, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Порядок в обуч." Margin="4"
                         Foreground="{StaticResource MaterialDesignBody}"/>
                <Button Grid.Column="8" Command="{Binding AddCommand}" Content="Добавить" 
                        Style="{StaticResource PrimaryButton}" Margin="4,0"
                        Foreground="{StaticResource MaterialDesignBody}"/>
            </Grid>
        </controls:EntityListControl.AddPanelContent>

        <controls:EntityListControl.MainContent>
            <StackPanel>
                <WrapPanel Margin="0,0,0,8">
                    <CheckBox Content="Показывать удалённые" IsChecked="{Binding ShowDeleted}" 
                              VerticalAlignment="Center" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <ComboBox ItemsSource="{Binding Difficulties}" DisplayMemberPath="DifficultyName" 
                              SelectedItem="{Binding SelectedDifficultyFilter}" 
                              materialDesign:HintAssist.Hint="Сложность" Width="140" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <ComboBox ItemsSource="{Binding Methods}" DisplayMemberPath="Name" 
                              SelectedItem="{Binding SelectedMethodFilter}" 
                              materialDesign:HintAssist.Hint="Метод" Width="140" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <ComboBox ItemsSource="{Binding Admins}" DisplayMemberPath="FullName" 
                              SelectedItem="{Binding SelectedAdminFilter}" 
                              materialDesign:HintAssist.Hint="Создатель" Width="150" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <ComboBox SelectedItem="{Binding IsTrainingFilter}" Width="120" Margin="4" Foreground="{StaticResource MaterialDesignBody}">
                        <ComboBoxItem Content="Все" IsSelected="True"/>
                        <ComboBoxItem Content="Обучение"/>
                        <ComboBoxItem Content="Практика"/>
                    </ComboBox>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,8">
                    <DatePicker SelectedDate="{Binding MinCreatedAt}" 
                                materialDesign:HintAssist.Hint="С даты созд." Width="140" Margin="4" 
                                Style="{StaticResource MaterialDesignDatePicker}" Foreground="{StaticResource MaterialDesignBody}"/>
                    <DatePicker SelectedDate="{Binding MaxCreatedAt}" 
                                materialDesign:HintAssist.Hint="По дату созд." Width="140" Margin="4" 
                                Style="{StaticResource MaterialDesignDatePicker}" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBlock Text="Баллы:" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding MinMaxScore, TargetNullValue=''}" Width="60" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="0" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding MaxMaxScore, TargetNullValue=''}" Width="60" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBlock Text="Порядок:" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding MinTutorialOrder, TargetNullValue=''}" Width="60" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="0" Foreground="{StaticResource MaterialDesignBody}"/>
                    <TextBox Text="{Binding MaxTutorialOrder, TargetNullValue=''}" Width="60" Margin="4" Foreground="{StaticResource MaterialDesignBody}"/>
                </WrapPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                              AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                              materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                              Foreground="{StaticResource MaterialDesignBody}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="Auto" MinWidth="50" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="150" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Содержание" Binding="{Binding Content, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="200" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Ответ" Binding="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="100" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Макс. балл" Binding="{Binding MaxScore, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="100" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTemplateColumn Header="Сложность" Width="Auto" MinWidth="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DifficultyName}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.Difficulties, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedValuePath="Id" DisplayMemberPath="DifficultyName"
                                                  SelectedValue="{Binding DifficultyId, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource MaterialDesignBody}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Метод" Width="Auto" MinWidth="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MethodName}" Foreground="{StaticResource MaterialDesignBody}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.Methods, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedValuePath="Id" DisplayMemberPath="Name"
                                                  SelectedValue="{Binding MethodId, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource MaterialDesignBody}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Обучение" Binding="{Binding IsTraining}" Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="Порядок в обуч." Binding="{Binding TutorialOrder}" Width="Auto" MinWidth="130" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Создал администратор" Binding="{Binding CreatedByAdminName}" Width="Auto" MinWidth="120" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto" MinWidth="150" Foreground="{StaticResource MaterialDesignBody}"/>
                            <DataGridCheckBoxColumn Header="Удален" Binding="{Binding IsDeleted, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="150"/>
                            <DataGridTextColumn Header="Дата удаления" Binding="{Binding DeletedAt, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="Auto" MinWidth="150" Foreground="{StaticResource MaterialDesignBody}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </StackPanel>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>