<Application x:Class="CryptoPuzzles.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CryptoPuzzles.ViewModels"
             xmlns:v="clr-namespace:CryptoPuzzles.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converts="clr-namespace:CryptoPuzzles.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme 
                    BaseTheme="Light" 
                    PrimaryColor="DeepPurple" 
                    SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Кастомный конвертер с поддержкой параметра -->
            <converts:BooleanToVisibilityConverterWithParameter x:Key="BoolToVis"/>
            
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <v:LoginView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
                <v:RegisterView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:UserViewModel}">
                <v:UserView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:UserProfileViewModel}">
                <v:UserProfileView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:TrainingViewModel}">
                <v:TrainingView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:PracticeViewModel}">
                <v:PracticeView/>
            </DataTemplate>

            <!-- Для админки -->
            <DataTemplate DataType="{x:Type vm:AdminViewModel}">
                <v:AdminView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AdminsViewModel}">
                <v:AdminsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                <v:UsersView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:TutorialsViewModel}">
                <v:TutorialsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DifficultiesViewModel}">
                <v:DifficultiesView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:MethodsViewModel}">
                <v:MethodsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:PuzzlesViewModel}">
                <v:PuzzlesView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:SessionsViewModel}">
                <v:SessionsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:HintsViewModel}">
                <v:HintsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:AdminProfileViewModel}">
                <v:AdminProfileView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:SessionProgressViewModel}">
                <v:SessionProgressView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:UserStatisticsViewModel}">
                <v:UserStatisticsView/>
            </DataTemplate>

            <Style x:Key="BackgroundCircle" TargetType="Ellipse">
                <Setter Property="Fill" Value="{DynamicResource PrimaryHueLightBrush}"/>
                <Setter Property="Opacity" Value="0.15"/>
                <Setter Property="IsHitTestVisible" Value="False"/>
            </Style>

            <Style x:Key="LogoCircle" TargetType="Border">
                <Setter Property="Width" Value="100"/>
                <Setter Property="Height" Value="100"/>
                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="CornerRadius" Value="50"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="InputContainer" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
            </Style>

            <Style x:Key="InputRow" TargetType="Grid">
                <Setter Property="Margin" Value="0,8,0,16"/>
            </Style>

            <Style x:Key="InputIconBorder" TargetType="Border">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                <Setter Property="CornerRadius" Value="22"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
            </Style>

            <Style x:Key="InputIcon" TargetType="materialDesign:PackIcon">
                <Setter Property="Width" Value="22"/>
                <Setter Property="Height" Value="22"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,16,0,24"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="26"/>
            </Style>

            <Style x:Key="RoundedOutlinedButton" 
                TargetType="Button" 
                BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="26"/>
            </Style>

            <Style x:Key="Divider" TargetType="Border">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Background" Value="{DynamicResource MaterialDesignDivider}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="DividerText" TargetType="TextBlock">
                <Setter Property="Margin" Value="16,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            </Style>

            <Style x:Key="Footer" TargetType="Border">
                <Setter Property="VerticalAlignment" Value="Bottom"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
            </Style>

            <!-- Стиль карточки администратора с анимацией при наведении -->
            <Style x:Key="AdminCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Margin" Value="12"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp5"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp12"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Trigger>
                </Style.Triggers>
                <Style.Resources>
                    <!-- Плавная анимация для всех изменений -->
                    <Storyboard x:Key="MouseEnterStory">
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.1"/>
                    </Storyboard>
                    <Storyboard x:Key="MouseLeaveStory">
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                    </Storyboard>
                </Style.Resources>
            </Style>

            <!-- Стиль заголовка карточки -->
            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="AdminActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="22"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="CardIcon" TargetType="materialDesign:PackIcon">
                <Setter Property="Width"          Value="32" />
                <Setter Property="Height"         Value="32" />
                <Setter Property="Margin"         Value="0 0 12 12" />
                <Setter Property="Foreground"     Value="{DynamicResource PrimaryHueMidBrush}" />
            </Style>

            <Style x:Key="CardStatRow" TargetType="StackPanel">
                <Setter Property="Orientation"    Value="Horizontal" />
                <Setter Property="Margin"         Value="0 0 0 12" />
            </Style>

            <Style x:Key="CardStatValue" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="FontWeight"          Value="Bold" />
                <Setter Property="Foreground"          Value="{DynamicResource PrimaryHueMidBrush}" />
            </Style>

            <!-- Исправленный стиль DataGrid для темной темы -->
            <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="RowBackground" Value="{DynamicResource MaterialDesignPaper}"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource MaterialDesignCardBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="materialDesign:DataGridAssist.CornerRadius" Value="26"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Style.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Style.Resources>
            </Style>

            <Style x:Key="DistinctMaterialDesignExpander" 
       TargetType="Expander" 
       BasedOn="{StaticResource MaterialDesignExpander}">

                <!-- Фон и рамка всего Expander (как карточка) -->
                <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                <Setter Property="BorderThickness" Value="1"/>

                <!-- Фон заголовка — используем светлый/тёмный вариант акцентного цвета (PrimaryHueLightBrush) -->
                <Setter Property="materialDesign:ExpanderAssist.HeaderBackground" 
            Value="{DynamicResource PrimaryHueLightBrush}"/>

                <!-- Лёгкая тень для выделения -->
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="8" 
                              ShadowDepth="2" 
                              Opacity="0.15" 
                              Color="Black"/>
                    </Setter.Value>
                </Setter>

                <!-- Цвет стрелки-иконки (ToggleButton) делаем акцентным -->
                <Style.Resources>
                    <Style TargetType="ToggleButton" 
               BasedOn="{StaticResource MaterialDesignExpanderToggleButton}">
                        <Setter Property="Foreground" 
                    Value="{DynamicResource PrimaryHueMidBrush}"/>
                    </Style>
                </Style.Resources>
            </Style>

            <!-- Стиль для кнопки перехода к теории (в стиле RoundedOutlinedButton) -->
            <Style x:Key="TheoryNavigationButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="22"/>
                <Setter Property="Padding" Value="20,0"/>
                <Setter Property="Margin" Value="0,0,16,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueDarkBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkBrush}"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль для иконки в кнопке навигации -->
            <Style x:Key="TheoryNavigationIcon" TargetType="materialDesign:PackIcon">
                <Setter Property="Width" Value="20"/>
                <Setter Property="Height" Value="20"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Style>

            <SolidColorBrush x:Key="MaterialDesignSuccessBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="MaterialDesignWarningBrush" Color="#FF9800"/>
            <SolidColorBrush x:Key="MaterialDesignErrorBrush" Color="#F44336"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>