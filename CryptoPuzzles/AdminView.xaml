<UserControl x:Class="Hairulin_02_01.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="{DynamicResource MaterialDesignPaper}" Height="462">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с навигацией -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                CornerRadius="0 0 30 30"
                Padding="24 16"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть с логотипом -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCrown" Width="32" Height="32" Foreground="White"/>
                    <TextBlock Text="CryptoPuzzles Admin" 
                             Foreground="White" 
                             FontSize="22" 
                             FontWeight="Bold" 
                             Margin="8,0,0,0" 
                             VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Центр с заголовком -->
                <TextBlock Grid.Column="1"
                         Text="Панель администратора"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                <!-- Правая часть с кнопками -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="ThemeButton_Click" 
                          Foreground="White" 
                          Cursor="Hand"
                          Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"/>
                            <TextBlock Text="Тема" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LogoutCommand}" 
                          Foreground="White" 
                          Cursor="Hand"
                          Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                            <TextBlock Text="Выход" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область с прокруткой -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      Margin="24">

            <!-- WrapPanel для автоматического расположения элементов -->
            <WrapPanel>
                <!-- Карточка для управления пользователями -->
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="300" 
                        Height="280"
                        CornerRadius="20" 
                        Margin="12" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="AccountGroup" 
                                                   Width="32" Height="32" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Пользователи" 
                                     FontSize="18" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Всего пользователей:" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="124" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Новых сегодня:" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="5" FontWeight="Bold" Foreground="Green"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Активных:" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="42" FontWeight="Bold"/>
                        </Grid>

                        <Button Content="Управление пользователями"
                              Style="{StaticResource MaterialDesignRaisedButton}"
                              Background="{DynamicResource PrimaryHueMidBrush}"
                              Foreground="White"
                              Margin="0,8,0,0"
                              Padding="8"
                              materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Border>

                <!-- Карточка для управления головоломками -->
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="300" 
                        Height="280"
                        CornerRadius="20" 
                        Margin="12" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Puzzle" 
                                                   Width="32" Height="32" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Головоломки" 
                                     FontSize="18" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Всего головоломок:" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="24" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Опубликовано:" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="18" FontWeight="Bold" Foreground="Green"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="В разработке:" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="6" FontWeight="Bold" Foreground="Orange"/>
                        </Grid>

                        <Button Content="Редактировать головоломки"
                              Style="{StaticResource MaterialDesignRaisedButton}"
                              Background="{DynamicResource PrimaryHueMidBrush}"
                              Foreground="White"
                              Margin="0,8,0,0"
                              Padding="8"
                              materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Border>

                <!-- Карточка для статистики -->
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="300" 
                        Height="280"
                        CornerRadius="20" 
                        Margin="12" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="ChartLine" 
                                                   Width="32" Height="32" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Статистика" 
                                     FontSize="18" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Решено всего:" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="847" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="За сегодня:" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="23" FontWeight="Bold"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Средний рейтинг:" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="4.5" FontWeight="Bold" Foreground="Gold"/>
                        </Grid>

                        <TextBlock Text="Выполнение плана" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <ProgressBar Value="65" Height="4" Margin="0,8,0,8" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                        <Button Content="Детальная статистика"
                              Style="{StaticResource MaterialDesignRaisedButton}"
                              Background="{DynamicResource PrimaryHueMidBrush}"
                              Foreground="White"
                              Margin="0,8,0,0"
                              Padding="8"
                              materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="300" 
                        Height="310"
                        CornerRadius="20" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Cog" 
                                                   Width="32" Height="32" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Настройки" 
                                     FontSize="18" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox Content="Автоматическая модерация" Margin="0,8"/>
                        <CheckBox Content="Уведомления администратору" Margin="0,8"/>
                        <CheckBox Content="Резервное копирование" Margin="0,8"/>

                        <ComboBox Margin="0,8,0,0" 
                                materialDesign:HintAssist.Hint="Язык интерфейса"
                                SelectedIndex="0">
                            <ComboBoxItem Content="Русский"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>

                        <Button Content="Сохранить настройки"
                              Style="{StaticResource MaterialDesignRaisedButton}"
                              Background="{DynamicResource PrimaryHueMidBrush}"
                              Foreground="White"
                              Margin="0,16,0,0"
                              Padding="8"
                              materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Border>

                <!-- Карточка для настроек -->

                <!-- DataGrid для отображения данных -->
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="624"
                        Height="280"
                        CornerRadius="20" 
                        Margin="12" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Table" 
                                                   Width="32" Height="32" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Последние действия" 
                                     FontSize="18" 
                                     FontWeight="Bold" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid AutoGenerateColumns="True" 
                                Height="180"
                                materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                                materialDesign:DataGridAssist.ColumnHeaderPadding="8 8 8 4"
                                Background="Transparent"
                                HeadersVisibility="Column"
                                GridLinesVisibility="None"
                                IsReadOnly="True">
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Карточка для добавления новых элементов -->
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        Width="300" 
                        Height="280"
                        CornerRadius="20" 
                        Margin="12" 
                        Padding="16"
                        materialDesign:ElevationAssist.Elevation="Dp5"
                        BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                        BorderThickness="2">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlusCircle" 
                                               Width="48" Height="48" 
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Opacity="0.5"/>
                        <TextBlock Text="Добавить новый элемент" 
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                 Opacity="0.5"
                                 Margin="0,8,0,0"
                                 TextWrapping="Wrap"
                                 HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>