<UserControl x:Class="CryptoPuzzles.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== ВЕРХНЯЯ ПАНЕЛЬ ========== -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                CornerRadius="0 0 30 30"
                Padding="24 16"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип + название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCrown" 
                                             Width="32" Height="32" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="CryptoPuzzles Admin"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               FontSize="22" FontWeight="Bold"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Заголовок страницы -->
                <TextBlock Grid.Column="1"
                           Text="Панель администратора"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Кнопки темы / выхода -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Foreground="White"
                            Command="{Binding ToggleThemeCommand}" 
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"/>
                            <TextBlock Text="Тема" Foreground="{DynamicResource MaterialDesignBody}" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LogoutCommand}"
                            Foreground="White"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                            <TextBlock Text="Выход" Foreground="{DynamicResource MaterialDesignBody}" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== ОСНОВНАЯ ОБЛАСТЬ С КАРТОЧКАМИ ========== -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="24">
            <!-- Сетка для двух рядов по четыре карточки -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ряд 1: Пользователи, Администраторы, Методы шифрования, Головоломки -->
                <!-- 1. ПОЛЬЗОВАТЕЛИ -->
                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Пользователи" Foreground="{DynamicResource MaterialDesignBody}" Style="{StaticResource CardTitleStyle}"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,12" Height="33">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Всего:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalUsers}" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Новых сегодня:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NewUsersToday}" FontWeight="Bold" Foreground="Green"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Активных:"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActiveUsers}" FontWeight="Bold"/>
                        </Grid>
                        <Button Content="Управление"
                                Command="{Binding NavigateToUsersCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 2. АДМИНИСТРАТОРЫ -->
                <Border Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="ShieldAccount" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Администраторы" Foreground="{DynamicResource MaterialDesignBody}" Style="{StaticResource CardTitleStyle}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToAdminsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 3. МЕТОДЫ ШИФРОВАНИЯ -->
                <Border Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Lock" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Методы шифрования" Foreground="{DynamicResource MaterialDesignBody}" Style="{StaticResource CardTitleStyle}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToMethodsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 4. ГОЛОВОЛОМКИ -->
                <Border Grid.Row="0" Grid.Column="3"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Puzzle" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Головоломки" Style="{StaticResource CardTitleStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToPuzzlesCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- Ряд 2: Подсказки, Игровые сессии, Туториалы, Настройки -->
                <!-- 5. ПОДСКАЗКИ -->
                <Border Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="LightbulbOn" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Подсказки" Style="{StaticResource CardTitleStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToHintsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 6. ИГРОВЫЕ СЕССИИ -->
                <Border Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Gamepad" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Игровые сессии" Style="{StaticResource CardTitleStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToSessionsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 7. ТУТОРИАЛЫ -->
                <Border Grid.Row="1" Grid.Column="2"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="School" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Туториалы" Style="{StaticResource CardTitleStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </StackPanel>
                        <Button Content="Управление"
                                Command="{Binding NavigateToTutorialsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>

                <!-- 8. НАСТРОЙКИ -->
                <Border Grid.Row="1" Grid.Column="3"
                        Style="{StaticResource AdminCardStyle}"
                        Width="280" HorizontalAlignment="Center" Margin="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Cog" Width="32" Height="32"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Настройки" Style="{StaticResource CardTitleStyle}" Foreground="{DynamicResource MaterialDesignBody}"/>
                        </StackPanel>
                        <ComboBox Margin="0,8,0,0"
                                  materialDesign:HintAssist.Hint="Язык"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Русский"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>
                        <Button Content="Сохранить"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                Margin="0,16,0,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Height="34"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>