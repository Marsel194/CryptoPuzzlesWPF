<Window x:Class="CryptoPuzzles.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="CryptoPuzzles - Криптографические головоломки"
        Width="1300" Height="900"
        WindowStartupLocation="CenterScreen">

    <materialDesign:DialogHost Identifier="RootDialogHost">
        <Grid>
            <ContentControl Content="{Binding CurrentView}" Background="{DynamicResource MaterialDesignCardBackground}"/>
            <materialDesign:Snackbar x:Name="MainSnackbar" 
                                      MessageQueue="{materialDesign:MessageQueue}" 
                                      Background="Transparent" 
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,20,20,0"/>
        </Grid>
    </materialDesign:DialogHost>
</Window>