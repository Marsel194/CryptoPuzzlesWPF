<UserControl x:Class="Hairulin_02_01.Views.MainAppView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                CornerRadius="0 0 30 30"
                Padding="24 16"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Puzzle" Width="32" Height="32" Foreground="White"/>
                    <TextBlock Text="CryptoPuzzles" Foreground="White" FontSize="22" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                         Text="Главная"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="ThemeButton_Click" 
                          Foreground="White" Cursor="Hand"
                          Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"/>
                            <TextBlock Text="Тема" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LogoutCommand}" 
                          Foreground="White" Cursor="Hand"
                          Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"/>
                            <TextBlock Text="Выход" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24">
            <StackPanel>
                <Border Background="{DynamicResource PrimaryHueLightBrush}"
                        CornerRadius="16" Padding="24" Margin="0,0,0,24"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Добро пожаловать в CryptoPuzzles!"
                                     FontSize="28" FontWeight="Bold"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Начните решать увлекательные криптографические головоломки"
                                     FontSize="16" Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     Opacity="0.8" TextWrapping="Wrap"/>

                            <Button Content="Начать решать"
                                  Background="White"
                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                  Width="150" Height="52" FontSize="16" FontWeight="Bold"
                                  Margin="0,24,0,0" Cursor="Hand"
                                  materialDesign:ButtonAssist.CornerRadius="26"/>
                        </StackPanel>

                        <materialDesign:PackIcon Grid.Column="1"
                                               Kind="PuzzleOutline"
                                               Width="120" Height="120"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Opacity="0.3"/>
                    </Grid>
                </Border>

                <TextBlock Text="Популярные головоломки"
                         FontSize="20" FontWeight="SemiBold"
                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                         Margin="0,0,0,16"/>

                <WrapPanel Margin="0,0,0,32">
                    <Border Background="{DynamicResource MaterialDesignPaper}"
                            Width="220" Height="220" CornerRadius="20" Margin="12" Padding="16"
                            Cursor="Hand" materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="LockOpenVariant" Width="64" Height="64" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Шифр Цезаря" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="Легкий" FontSize="12" Foreground="Green" HorizontalAlignment="Center"/>
                            <ProgressBar Value="75" Height="4" Margin="16,16,16,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MaterialDesignPaper}"
                            Width="220" Height="220" CornerRadius="20" Margin="12" Padding="16"
                            Cursor="Hand" materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Lock" Width="64" Height="64" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="AES-128" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="Средний" FontSize="12" Foreground="Orange" HorizontalAlignment="Center"/>
                            <ProgressBar Value="30" Height="4" Margin="16,16,16,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MaterialDesignPaper}"
                            Width="220" Height="220" CornerRadius="20" Margin="12" Padding="16"
                            Cursor="Hand" materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="LockAlert" Width="64" Height="64" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="RSA" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="Сложный" FontSize="12" Foreground="Red" HorizontalAlignment="Center"/>
                            <ProgressBar Value="10" Height="4" Margin="16,16,16,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MaterialDesignPaper}"
                            Width="220" Height="220" CornerRadius="20" Margin="12" Padding="16"
                            Cursor="Hand" materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="LockOutline" Width="64" Height="64" 
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Base64" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="Легкий" FontSize="12" Foreground="Green" HorizontalAlignment="Center"/>
                            <ProgressBar Value="100" Height="4" Margin="16,16,16,0" Foreground="Green"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="16" Padding="24" Margin="0,0,0,24"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CheckCircle" Width="32" Height="32" Foreground="Green" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Решено" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <TextBlock Text="12" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Star" Width="32" Height="32" Foreground="Gold" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Очки" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <TextBlock Text="1250" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Trophy" Width="32" Height="32" Foreground="Silver" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Место" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>