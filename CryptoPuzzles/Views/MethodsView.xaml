<UserControl x:Class="CryptoPuzzles.Views.MethodsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <controls:EntityListControl 
        Title="Методы шифрования"
        BackCommand="{Binding BackCommand}"
        AddCommand="{Binding AddCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        SaveCommand="{Binding SaveCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="True"
        AddPanelTitle="Новый метод"
        IsSaveButtonVisible="True">

        <!-- Панель добавления -->
        <controls:EntityListControl.AddPanelContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewItem.Name, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Название метода" Margin="4"/>
                <Button Grid.Column="1" Command="{Binding AddCommand}" Content="Добавить" 
                        Style="{StaticResource PrimaryButton}" Margin="4,0"/>
            </Grid>
        </controls:EntityListControl.AddPanelContent>

        <!-- Основное содержимое (DataGrid) -->
        <controls:EntityListControl.MainContent>
            <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                      AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding Id}" Content="Удалить" 
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="{DynamicResource MaterialDesignValidationErrorBrush}" 
                                        MinWidth="70" Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>