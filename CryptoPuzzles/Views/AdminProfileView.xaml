<UserControl x:Class="CryptoPuzzles.Client.Views.AdminProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Client.Helpers">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24" MaxWidth="600" HorizontalAlignment="Center">
            <!-- Кнопка назад -->
            <Button Command="{Binding CloseCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                    <TextBlock Text="Назад" Margin="8,0,0,0" FontSize="16"/>
                </StackPanel>
            </Button>

            <!-- Заголовок -->
            <TextBlock Text="Профиль администратора"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       Margin="0,0,0,24"/>

            <!-- Карточка с данными -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20"
                    Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>
                    <!-- Заголовок с кнопкой -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Личные данные"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- Кнопка Изменить -->
                        <Button Grid.Column="1"
                                Command="{Binding EditCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Изменить" Margin="5,0,0,0"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Поля данных -->
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Логин (Row 0) - всегда только для чтения -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Логин:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Login}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <!-- Имя (Row 1) -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Имя:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding FirstName}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Имя"
                                 Foreground="{DynamicResource MaterialDesignBody}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Фамилия (Row 2) -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Фамилия:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding LastName}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Фамилия"
                                 Foreground="{DynamicResource MaterialDesignBody}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Отчество (Row 3) -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Отчество:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding MiddleName}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Отчество"
                                 Foreground="{DynamicResource MaterialDesignBody}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Новый пароль (Row 4) -->
                        <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,8,0,16">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="Lock" Width="22" Height="22" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtNewPassword"
                                         Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Новый пароль (оставьте пустым, если не меняете)"
                                         helpers:PasswordHelper.Attach="True"
                                         helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="64"
                                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>

                        <!-- Подтверждение пароля (Row 5) -->
                        <Grid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,8,0,16">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="LockCheck" Width="22" Height="22" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtConfirmPassword"
                                         Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Подтверждение пароля"
                                         helpers:PasswordHelper.Attach="True"
                                         helpers:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="64"
                                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                    </Grid>

                    <!-- Кнопки сохранения/отмены в режиме редактирования -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Content="Сохранить"
                                Margin="0,0,16,0"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                        <Button Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Отмена"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>