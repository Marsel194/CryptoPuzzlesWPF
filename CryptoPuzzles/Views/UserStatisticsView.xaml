<UserControl x:Class="CryptoPuzzles.Views.UserStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <controls:EntityListControl 
        Title="Статистика пользователей"
        BackCommand="{Binding BackCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="False"
        IsSaveButtonVisible="False">

        <!-- Основное содержимое (DataGrid) -->
        <controls:EntityListControl.MainContent>
            <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID пользователя" Binding="{Binding UserId}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding UserLogin}" Width="Auto" MinWidth="100"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Username}" Width="Auto" MinWidth="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="Auto" MinWidth="150"/>
                    <DataGridTextColumn Header="Сессий" Binding="{Binding TotalSessions}" Width="Auto" MinWidth="60"/>
                    <DataGridTextColumn Header="Решено" Binding="{Binding TotalPuzzlesSolved}" Width="Auto" MinWidth="70"/>
                    <DataGridTextColumn Header="Очки" Binding="{Binding TotalScore}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Подсказок" Binding="{Binding TotalHintsUsed}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Ср. балл" Binding="{Binding AvgScorePerSession}" Width="Auto" MinWidth="70"/>
                    <DataGridTextColumn Header="Последняя активность" Binding="{Binding LastActive, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto" MinWidth="150"/>
                    <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegisteredAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto" MinWidth="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>