<UserControl x:Class="CryptoPuzzles.Views.AdminsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Helpers">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с заголовком и кнопкой назад -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding BackCommand}" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Вернуться в админ-панель" Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Назад" FontSize="16" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
            </Button>
            <TextBlock Grid.Column="1" Text="Администраторы" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>

        <!-- Панель добавления -->
        <Border Grid.Row="1" Style="{StaticResource InputContainer}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Новый администратор" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewItem.Login, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Логин" Margin="4"/>
                    <TextBox Grid.Column="1" Text="{Binding NewItem.FirstName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Имя" Margin="4"/>
                    <TextBox Grid.Column="2" Text="{Binding NewItem.LastName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Фамилия" Margin="4"/>
                    <TextBox Grid.Column="3" Text="{Binding NewItem.MiddleName, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Отчество" Margin="4"/>
                    <PasswordBox Grid.Column="4" helpers:PasswordHelper.Attach="True" helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Пароль" Margin="4"/>
                    <Button Grid.Column="5" Command="{Binding AddCommand}" Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="4,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Панель фильтрации и экспорта -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Введите текст..." Padding="4"/>
            <Button Grid.Column="2" Command="{Binding ClearFilterCommand}" Content="Очистить" Style="{StaticResource MaterialDesignFlatButton}" Margin="8,0,0,0"/>
            <Button Grid.Column="3" Command="{Binding ExportToExcelCommand}" Content="Экспорт в Excel" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Width="140"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding ItemsView}" 
                  SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="False" 
                  CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, UpdateSourceTrigger=PropertyChanged, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="150"/>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding Id}" Content="Удалить" Style="{StaticResource MaterialDesignFlatButton}" Foreground="Red"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка Сохранить -->
        <Button Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center" 
                Command="{Binding SaveCommand}" Content="Сохранить изменения" 
                Style="{StaticResource PrimaryButton}" Margin="0,16,0,0" Width="200"/>
    </Grid>
</UserControl>