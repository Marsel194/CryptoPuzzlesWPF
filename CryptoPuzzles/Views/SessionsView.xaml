<UserControl x:Class="CryptoPuzzles.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <controls:EntityListControl 
        Title="Игровые сессии"
        BackCommand="{Binding BackCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="False"
        IsSaveButtonVisible="False">

        <!-- Основное содержимое (DataGrid) -->
        <controls:EntityListControl.MainContent>
            <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" MinWidth="50"/>
                    <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLogin}" Width="Auto" MinWidth="120"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Username}" Width="Auto" MinWidth="120"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding SessionType}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Текущий шаг" Binding="{Binding CurrentTutorialIndex}" Width="Auto" MinWidth="100"/>
                    <DataGridTextColumn Header="Счёт" Binding="{Binding TotalScore}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding SessionStart, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto" MinWidth="150"/>
                    <DataGridTextColumn Header="Завершено" Binding="{Binding CompletedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="Auto" MinWidth="150"/>
                    <DataGridCheckBoxColumn Header="Завершена" Binding="{Binding IsCompleted}" Width="Auto" MinWidth="90"/>
                    <DataGridTextColumn Header="Головоломок" Binding="{Binding PuzzlesCount}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="Решено" Binding="{Binding SolvedCount}" Width="Auto" MinWidth="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>