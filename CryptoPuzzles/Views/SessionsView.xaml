<UserControl x:Class="CryptoPuzzles.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с заголовком и кнопкой назад -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Кнопка назад -->
            <Button Grid.Column="0" 
                    Command="{Binding BackCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="Вернуться в админ-панель"
                    Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" 
                                            Width="24" 
                                            Height="24"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Назад" 
                              FontSize="16"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
            </Button>

            <!-- Заголовок -->
            <TextBlock Grid.Column="1" 
                       Text="Игровые сессии" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLogin}" IsReadOnly="True" Width="120"/>
                <DataGridTextColumn Header="Счёт" Binding="{Binding Score}" Width="80"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding SessionStartTime, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Текущая головоломка" Binding="{Binding CurrentPuzzleTitle}" Width="150"/>
                <DataGridCheckBoxColumn Header="Обучение пройдено" Binding="{Binding TrainingCompleted}"/>
                <DataGridTextColumn Header="Использовано подсказок" Binding="{Binding HintsUsed}" Width="80"/>
                <DataGridTextColumn Header="Завершена" Binding="{Binding CompletedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding Id}" 
                                    Content="Удалить" 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="Red"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка Сохранить -->
        <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" 
                Command="{Binding SaveCommand}" Content="Сохранить изменения" 
                Style="{StaticResource PrimaryButton}" Margin="0,16,0,0" Width="200"/>
    </Grid>
</UserControl>