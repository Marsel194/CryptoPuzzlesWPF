<UserControl x:Class="CryptoPuzzles.Views.SessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <controls:EntityListControl 
        Title="Игровые сессии"
        BackCommand="{Binding BackCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="False"
        IsSaveButtonVisible="False">

        <!-- Основное содержимое (DataGrid) -->
        <controls:EntityListControl.MainContent>
            <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLogin}" Width="120"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding SessionType}" Width="80"/>
                    <DataGridTextColumn Header="Счёт" Binding="{Binding TotalScore}" Width="80"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding SessionStart, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                    <DataGridTextColumn Header="Завершено" Binding="{Binding CompletedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Завершена" Binding="{Binding IsCompleted}"/>
                    <DataGridTextColumn Header="Головоломок" Binding="{Binding PuzzlesCount}" Width="80"/>
                    <DataGridTextColumn Header="Решено" Binding="{Binding SolvedCount}" Width="80"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding Id}" Content="Удалить" 
                                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="Red" 
                                        MinWidth="70" Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>