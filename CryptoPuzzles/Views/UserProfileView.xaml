<UserControl x:Class="CryptoPuzzles.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <!-- Кнопка назад -->
            <Button Command="{Binding CloseProfileCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                    <TextBlock Text="Назад" Margin="8,0,0,0" FontSize="16"/>
                </StackPanel>
            </Button>

            <!-- Заголовок -->
            <TextBlock Text="Профиль пользователя"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,24"/>

            <!-- Прогресс -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20"
                    Padding="24"
                    Margin="0,0,0,24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Обучение -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Обучение"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                   Kind="BookOpenOutline"
                                                   Width="24" Height="24"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding TrainingProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding TrainingProgress}"
                                         Maximum="100"
                                         Height="8"
                                         Margin="0,8,0,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Grid>
                        <TextBlock Text="{Binding TrainingProgress, StringFormat=Пройдено {0} из 100%}"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Практика -->
                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="Практика"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                   Kind="PuzzleOutline"
                                                   Width="24" Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                   Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding PracticeProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource SecondaryHueMidBrush}"/>

                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding PracticeProgress}"
                                         Maximum="100"
                                         Height="8"
                                         Margin="0,8,0,0"
                                         Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        </Grid>
                        <TextBlock Text="{Binding PracticeProgress, StringFormat=Решено {0} из 100%}"
                                   FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Данные пользователя -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20"
                    Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Личные данные"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <Button Grid.Column="1"
                                Command="{Binding EditCommand}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20"/>
                                <TextBlock Text="Изменить" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Логин -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Логин:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Login}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding Login}"
                                 FontSize="16"
                                 Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Логин"/>

                        <!-- Email -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Email:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Email}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding Email}"
                                 FontSize="16"
                                 Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Email"/>

                        <!-- Имя пользователя (Username) -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Имя:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Username}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding Username}"
                                 FontSize="16"
                                 Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Имя"/>
                    </Grid>

                    <!-- Кнопки сохранения/отмены в режиме редактирования -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <Button Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Content="Сохранить"
                                Margin="0,0,16,0"/>
                        <Button Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Отмена"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>