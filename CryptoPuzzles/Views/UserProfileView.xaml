<UserControl x:Class="CryptoPuzzles.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Converters">
    <UserControl.Resources>
        <helpers:BooleanToVisibilityConverterWithParameter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <!-- Кнопка назад -->
            <Button Command="{Binding CloseCommand}"
                Style="{StaticResource MaterialDesignFlatButton}"
                HorizontalAlignment="Left"
                Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                    <TextBlock Text="Назад" Margin="8,0,0,0" FontSize="16"/>
                </StackPanel>
            </Button>

            <!-- Заголовок -->
            <TextBlock Text="Профиль пользователя"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                       Margin="0,0,0,24"/>

            <!-- Прогресс (без изменений) -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20" Padding="24" Margin="0,0,0,24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Обучение" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                   Kind="BookOpenOutline" Width="24" Height="24"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding TrainingProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding TrainingProgress}" Maximum="100"
                                         Height="8" Margin="0,8,0,0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Grid>
                        <TextBlock Text="{Binding TrainingProgress, StringFormat=Пройдено {0} из 100%}"
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="Практика" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryHueMidBrush}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                   Kind="PuzzleOutline" Width="24" Height="24"
                                                   Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                   Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding PracticeProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding PracticeProgress}" Maximum="100"
                                         Height="8" Margin="0,8,0,0"
                                         Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        </Grid>
                        <TextBlock Text="{Binding PracticeProgress, StringFormat=Решено {0} из 100%}"
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Данные пользователя -->
            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20" Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>
                    <!-- Заголовок с кнопкой -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Личные данные"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <Button Grid.Column="1"
                                Command="{Binding EditCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20"/>
                                <TextBlock Text="Изменить" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Поля данных -->
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Логин -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Логин:" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Login}" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center" Margin="0,0,0,16"/>

                        <!-- Email -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Email:" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Email}" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center" Margin="0,0,0,16"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" Margin="0,0,0,16"
                                 Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                 materialDesign:HintAssist.Hint="Email"/>

                        <!-- Имя -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Имя:" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Username}" FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center" Margin="0,0,0,16"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}, ConverterParameter=False}"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" Margin="0,0,0,16"
                                 Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                 materialDesign:HintAssist.Hint="Имя"/>

                        <!-- Новый пароль -->
                        <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,16"
                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource PrimaryHueLightBrush}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="Lock" Width="22" Height="22" 
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtNewPassword"
                               Grid.Column="1"
                               materialDesign:HintAssist.Hint="Новый пароль (оставьте пустым, если не меняете)"
                               helpers:PasswordHelper.Attach="True"
                               helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               MaxLength="64"
                               Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                        </Grid>

                        <!-- Подтверждение пароля -->
                        <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,8,0,16"
                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource PrimaryHueLightBrush}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="LockCheck" Width="22" Height="22" 
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtConfirmPassword"
                               Grid.Column="1"
                               materialDesign:HintAssist.Hint="Подтверждение пароля"
                               helpers:PasswordHelper.Attach="True"
                               helpers:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               MaxLength="64"
                               Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                        </Grid>
                    </Grid>

                    <!-- Кнопки сохранения/отмены -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                        <Button Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Content="Сохранить" Margin="0,0,16,0"/>
                        <Button Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Отмена"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>