<UserControl x:Class="CryptoPuzzles.Client.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Client.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <Button Command="{Binding CloseCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                    <TextBlock Text="Назад" Margin="8,0,0,0" FontSize="16"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Профиль пользователя"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       Margin="0,0,0,24"/>

            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20" Padding="24" Margin="0,0,0,24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Обучение" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                     Kind="BookOpenOutline" Width="24" Height="24"
                                                     Foreground="{DynamicResource MaterialDesignBody}"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding TrainingProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding TrainingProgress, Mode=OneWay}" Maximum="100"
                                         Height="8" Margin="0,8,0,0"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                        <TextBlock Text="{Binding TrainingProgress, StringFormat=Пройдено {0} из 100%}"
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBody}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="Практика" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                                     Kind="PuzzleOutline" Width="24" Height="24"
                                                     Foreground="{DynamicResource MaterialDesignBody}"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding PracticeProgress, StringFormat={}{0}%}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"/>
                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                         Value="{Binding PracticeProgress, Mode=OneWay}" Maximum="100"
                                         Height="8" Margin="0,8,0,0"
                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                        </Grid>
                        <TextBlock Text="{Binding PracticeProgress, StringFormat=Решено {0} из 100%}"
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBody}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20" Padding="24"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Личные данные"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                        <Button Grid.Column="1"
                                Command="{Binding EditCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20"
                                                         Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="Изменить" Margin="5,0,0,0"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Логин:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Login}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Email:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Email}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Email"
                                 Foreground="{DynamicResource MaterialDesignBody}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Имя:"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Username}"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16"
                                 Margin="0,0,0,16"
                                 materialDesign:HintAssist.Hint="Имя"
                                 Foreground="{DynamicResource MaterialDesignBody}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,16">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="Lock" Width="22" Height="22" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtNewPassword"
                                         Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Новый пароль (оставьте пустым, если не меняете)"
                                         helpers:PasswordHelper.Attach="True"
                                         helpers:PasswordHelper.Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="64"
                                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                        </Grid>

                        <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,8,0,16">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" 
                                    Background="{DynamicResource MaterialDesignCardBackground}"
                                    CornerRadius="22" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="LockCheck" Width="22" Height="22" 
                                                         Foreground="{DynamicResource MaterialDesignBody}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="txtConfirmPassword"
                                         Grid.Column="1"
                                         materialDesign:HintAssist.Hint="Подтверждение пароля"
                                         helpers:PasswordHelper.Attach="True"
                                         helpers:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="64"
                                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"/>
                        </Grid>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Content="Сохранить"
                                Margin="0,0,16,0"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                        <Button Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Content="Отмена"
                                Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="20" Padding="24" Margin="0,24,0,0"
                    materialDesign:ElevationAssist.Elevation="Dp4">
                <StackPanel>
                    <TextBlock Text="Управление прогрессом"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="Если вы хотите начать обучение заново, вы можете сбросить текущий прогресс. Это удалит все данные о вашей текущей активной сессии."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               Margin="0,0,0,16"/>
                    <Button Command="{Binding DeleteProgressCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="Red"
                            Foreground="White"
                            Height="44"
                            materialDesign:ButtonAssist.CornerRadius="22"
                            IsEnabled="{Binding HasActiveSession}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Удалить текущий прогресс" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>