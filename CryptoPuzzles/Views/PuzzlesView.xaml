<UserControl x:Class="CryptoPuzzles.Views.PuzzlesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Головоломки" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Панель добавления -->
        <Border Grid.Row="1" Style="{StaticResource InputContainer}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Новая головоломка" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewItem.Title, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Название" Margin="4"/>
                    <TextBox Grid.Column="1" Text="{Binding NewItem.Content, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Содержание" Margin="4"/>
                    <TextBox Grid.Column="2" Text="{Binding NewItem.Answer, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Ответ" Margin="4"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding Difficulties}" SelectedValuePath="Id" DisplayMemberPath="DifficultyName" 
                              SelectedValue="{Binding NewItem.DifficultyId}" materialDesign:HintAssist.Hint="Сложность" Margin="4"/>
                    <ComboBox Grid.Column="4" ItemsSource="{Binding Methods}" SelectedValuePath="Id" DisplayMemberPath="Name" 
                              SelectedValue="{Binding NewItem.MethodId}" materialDesign:HintAssist.Hint="Метод" Margin="4"/>
                    <Button Grid.Column="5" Command="{Binding AddCommand}" Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="4,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Содержание" Binding="{Binding Content}" Width="200"/>
                <DataGridTextColumn Header="Ответ" Binding="{Binding Answer}" Width="100"/>
                <DataGridTextColumn Header="Макс. балл" Binding="{Binding MaxScore}" Width="80"/>
                <!-- Сложность: редактирование через ComboBox -->
                <DataGridTemplateColumn Header="Сложность" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DifficultyName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.Difficulties, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      SelectedValuePath="Id" DisplayMemberPath="DifficultyName"
                                      SelectedValue="{Binding DifficultyId, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <!-- Метод: редактирование через ComboBox -->
                <DataGridTemplateColumn Header="Метод" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MethodName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.Methods, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      SelectedValuePath="Id" DisplayMemberPath="Name"
                                      SelectedValue="{Binding MethodId, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Header="Обучение" Binding="{Binding IsTraining}"/>
                <DataGridTextColumn Header="Порядок" Binding="{Binding TutorialOrder}"/>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding Id}" 
                                    Content="Удалить" 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="Red"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка Сохранить -->
        <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Command="{Binding SaveCommand}" Content="Сохранить изменения" 
                Style="{StaticResource PrimaryButton}" Margin="0,16,0,16" Width="200"/>
    </Grid>
</UserControl>