<UserControl x:Class="CryptoPuzzles.Views.PuzzlesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CryptoPuzzles.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Helpers">
    <controls:EntityListControl 
        Title="Головоломки"
        BackCommand="{Binding BackCommand}"
        AddCommand="{Binding AddCommand}"
        ClearFilterCommand="{Binding ClearFilterCommand}"
        ExportToExcelCommand="{Binding ExportToExcelCommand}"
        SaveCommand="{Binding SaveCommand}"
        FilterText="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
        IsAddPanelVisible="True"
        AddPanelTitle="Новая головоломка"
        IsSaveButtonVisible="True">

        <!-- Панель добавления -->
        <controls:EntityListControl.AddPanelContent>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewItem.Title, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Название" Margin="4"/>
                <TextBox Grid.Column="1" Text="{Binding NewItem.Content, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Содержание" Margin="4"/>
                <TextBox Grid.Column="2" Text="{Binding NewItem.Answer, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Ответ" Margin="4"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding Difficulties}" SelectedValuePath="Id" 
                          DisplayMemberPath="DifficultyName" SelectedValue="{Binding NewItem.DifficultyId}" 
                          helpers:ComboBoxBehavior.AutoOpenOnEdit="True" materialDesign:HintAssist.Hint="Сложность" Margin="4"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding Methods}" SelectedValuePath="Id" 
                          DisplayMemberPath="Name" SelectedValue="{Binding NewItem.MethodId}" 
                          helpers:ComboBoxBehavior.AutoOpenOnEdit="True" materialDesign:HintAssist.Hint="Метод" Margin="4"/>
                <Button Grid.Column="5" Command="{Binding AddCommand}" Content="Добавить" 
                        Style="{StaticResource PrimaryButton}" Margin="4,0"/>
            </Grid>
        </controls:EntityListControl.AddPanelContent>

        <!-- Основное содержимое (DataGrid) -->
        <controls:EntityListControl.MainContent>
            <DataGrid ItemsSource="{Binding ItemsView}" SelectedItem="{Binding SelectedItem}" 
                      AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                    <DataGridTextColumn Header="Содержание" Binding="{Binding Content, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                    <DataGridTextColumn Header="Ответ" Binding="{Binding Answer, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                    <DataGridTextColumn Header="Макс. балл" Binding="{Binding MaxScore, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                    <!-- Сложность -->
                    <DataGridTemplateColumn Header="Сложность" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DifficultyName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Difficulties, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedValuePath="Id" DisplayMemberPath="DifficultyName"
                                          SelectedValue="{Binding DifficultyId, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Метод -->
                    <DataGridTemplateColumn Header="Метод" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MethodName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Methods, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedValuePath="Id" DisplayMemberPath="Name"
                                          SelectedValue="{Binding MethodId, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridCheckBoxColumn Header="Обучение" Binding="{Binding IsTraining}"/>
                    <DataGridTextColumn Header="Порядок в обуч." Binding="{Binding TutorialOrder}"/>

                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding Id}" Content="Удалить" 
                                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="Red" 
                                        MinWidth="70" Padding="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </controls:EntityListControl.MainContent>
    </controls:EntityListControl>
</UserControl>