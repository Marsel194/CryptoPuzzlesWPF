<UserControl x:Class="CryptoPuzzles.Views.ConfirmationDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="400">
    <materialDesign:Card UniformCornerRadius="20" Padding="24" Background="{DynamicResource MaterialDesignPaper}">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16"/>
            <TextBlock Text="{Binding Message}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource MaterialDesignOutlinedButton}" materialDesign:ButtonAssist.CornerRadius="20" Padding="16,8" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                <Button Content="Подтвердить" Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesignCardBackground}" Foreground="{DynamicResource MaterialDesignBody}" materialDesign:ButtonAssist.CornerRadius="20" Padding="16,8" Command="{Binding ConfirmCommand}" Height="35"/>
            </StackPanel>
        </StackPanel>
    </materialDesign:Card>
</UserControl>