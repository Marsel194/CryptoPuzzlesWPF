<UserControl x:Class="CryptoPuzzles.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CryptoPuzzles.Views"
             xmlns:helpers="clr-namespace:CryptoPuzzles.Helpers">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:InverseBooleanConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                CornerRadius="0 0 30 30"
                Padding="24 16"
                materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Puzzle" Width="32" Height="32" Foreground="White"/>
                    <TextBlock Text="CryptoPuzzles" Foreground="White" FontSize="22" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding Username, StringFormat='Привет, {0}!'}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Кнопка профиля -->
                    <Button Command="{Binding OpenProfileCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,8,0">
                        <materialDesign:PackIcon Kind="AccountCircle" Width="24" Height="24" Foreground="White"/>
                    </Button>

                    <Button Command="{Binding ToggleThemeCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"
                                                   Foreground="White"/>
                            <TextBlock Text="Тема" Foreground="White" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LogoutCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"
                                                   Foreground="White"/>
                            <TextBlock Text="Выход" Foreground="White" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="24">
            <!-- Главный экран (карточки обучения/практики) -->
            <Grid Visibility="{Binding IsProfileOpen, Converter={StaticResource BoolToVis}, ConverterParameter=False}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Выберите режим"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,48"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <!-- Карточка Обучение -->
                        <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                Width="280" Height="320"
                                CornerRadius="24"
                                Margin="20"
                                Cursor="Hand"
                                materialDesign:ElevationAssist.Elevation="Dp8">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding StartTrainingCommand}"/>
                            </Border.InputBindings>
                            <Border.Resources>
                                <Style TargetType="Border" BasedOn="{StaticResource AdminCardStyle}"/>
                            </Border.Resources>
                            <StackPanel VerticalAlignment="Center" Margin="24">
                                <materialDesign:PackIcon Kind="School" Width="80" Height="80"
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="Обучение"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,24,0,12"/>
                                <TextBlock Text="Изучите теорию шифрования и пройдите обучающие уроки"
                                           FontSize="14"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка Практика -->
                        <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                Width="280" Height="320"
                                CornerRadius="24"
                                Margin="20"
                                Cursor="Hand"
                                materialDesign:ElevationAssist.Elevation="Dp8">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding StartPracticeCommand}"/>
                            </Border.InputBindings>
                            <Border.Resources>
                                <Style TargetType="Border" BasedOn="{StaticResource AdminCardStyle}"/>
                            </Border.Resources>
                            <StackPanel VerticalAlignment="Center" Margin="24">
                                <materialDesign:PackIcon Kind="Puzzle" Width="80" Height="80"
                                                       Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="Практика"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource SecondaryHueMidBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,24,0,12"/>
                                <TextBlock Text="Решайте криптографические головоломки разной сложности"
                                           FontSize="14"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <!-- Профиль -->
            <Grid Visibility="{Binding IsProfileOpen, Converter={StaticResource BoolToVis}}">
                <local:UserProfileView DataContext="{Binding}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>