<UserControl x:Class="CryptoPuzzles.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CryptoPuzzles.Views"
             xmlns:converters="clr-namespace:CryptoPuzzles.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (виден только на главном экране) -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                CornerRadius="0 0 30 30"
                Padding="24 16"
                materialDesign:ElevationAssist.Elevation="Dp8"
                Visibility="{Binding CurrentSection, Converter={StaticResource NullToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Puzzle" Width="32" Height="32" 
                                              Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    <TextBlock Text="CryptoPuzzles" 
                               Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" 
                               FontSize="22" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding Username, StringFormat='Привет, {0}!'}"
                           Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding OpenProfileCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,8,0">
                        <materialDesign:PackIcon Kind="AccountCircle" Width="24" Height="24" 
                                                  Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Button>

                    <Button Command="{Binding ToggleThemeCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                            <TextBlock Text="Тема" 
                                       Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" 
                                       Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LogoutCommand}"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20"
                                                      Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                            <TextBlock Text="Выход" 
                                       Foreground="{DynamicResource PrimaryHueMidForegroundBrush}" 
                                       Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контентная область -->
        <Grid Grid.Row="1" Margin="24">
            <!-- Главный экран (виден, когда CurrentSection == null) -->
            <Grid Visibility="{Binding CurrentSection, Converter={StaticResource NullToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Блок статистики -->
                        <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                CornerRadius="16" Padding="24" Margin="0,0,0,24"
                                materialDesign:ElevationAssist.Elevation="Dp2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CheckCircle" Width="32" Height="32" Foreground="Green" Margin="0,0,8,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Решено" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                        <TextBlock Text="{Binding SolvedCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Star" Width="32" Height="32" Foreground="Gold" Margin="0,0,8,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Очки" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                        <TextBlock Text="{Binding Score}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Карточки выбора режима -->
                        <TextBlock Text="Выберите режим"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>

                        <WrapPanel HorizontalAlignment="Center">
                            <!-- Карточка Обучение -->
                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                    Width="280" Height="320"
                                    CornerRadius="24"
                                    Margin="20"
                                    Cursor="Hand"
                                    materialDesign:ElevationAssist.Elevation="Dp8">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick" Command="{Binding StartTrainingCommand}"/>
                                </Border.InputBindings>
                                <StackPanel VerticalAlignment="Center" Margin="24">
                                    <materialDesign:PackIcon Kind="School" Width="80" Height="80"
                                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                           HorizontalAlignment="Center"/>
                                    <TextBlock Text="Обучение"
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,24,0,12"/>
                                    <TextBlock Text="Изучите теорию шифрования и пройдите обучающие уроки"
                                               FontSize="14"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка Практика -->
                            <Border Background="{DynamicResource MaterialDesignCardBackground}"
                                    Width="280" Height="320"
                                    CornerRadius="24"
                                    Margin="20"
                                    Cursor="Hand"
                                    materialDesign:ElevationAssist.Elevation="Dp8">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick" Command="{Binding StartPracticeCommand}"/>
                                </Border.InputBindings>
                                <StackPanel VerticalAlignment="Center" Margin="24">
                                    <materialDesign:PackIcon Kind="Puzzle" Width="80" Height="80"
                                                           Foreground="{DynamicResource SecondaryHueMidBrush}"
                                                           HorizontalAlignment="Center"/>
                                    <TextBlock Text="Практика"
                                               FontSize="28" FontWeight="Bold"
                                               Foreground="{DynamicResource SecondaryHueMidBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,24,0,12"/>
                                    <TextBlock Text="Решайте криптографические головоломки разной сложности"
                                               FontSize="14"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Экран профиля или другого раздела (виден, когда CurrentSection != null) -->
            <ContentControl Content="{Binding CurrentSection}"
                            Visibility="{Binding CurrentSection, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
        </Grid>
    </Grid>
</UserControl>