<UserControl x:Class="CryptoPuzzles.Views.TutorialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Верхняя панель с заголовком и кнопкой -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Панель добавления -->
            <RowDefinition Height="*"/>
            <!-- 2: DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Кнопка сохранить -->
        </Grid.RowDefinitions>

        <!-- Верхняя панель с заголовком и кнопкой назад (Row 0) -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Кнопка назад -->
            <Button Grid.Column="0" 
                    Command="{Binding BackCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="Вернуться в админ-панель"
                    Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ArrowLeft" 
                                            Width="24" 
                                            Height="24"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Назад" 
                              FontSize="16"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
            </Button>

            <!-- Заголовок -->
            <TextBlock Grid.Column="1" 
                       Text="Туториалы" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Панель добавления (Row 1) -->
        <Border Grid.Row="1" 
                Style="{StaticResource InputContainer}" 
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Новый урок" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" 
                              ItemsSource="{Binding Methods}" 
                              SelectedValuePath="Id" 
                              DisplayMemberPath="Name" 
                              SelectedValue="{Binding NewItem.MethodId}" 
                              materialDesign:HintAssist.Hint="Метод" 
                              Margin="4"/>

                    <TextBox Grid.Column="1" 
                             Text="{Binding NewItem.TheoryTitle, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Заголовок" 
                             Margin="4"/>

                    <TextBox Grid.Column="2" 
                             Text="{Binding NewItem.TheoryContent, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Содержание" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="60"
                             Margin="4"/>

                    <TextBox Grid.Column="3" 
                             Text="{Binding NewItem.SortOrder, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Порядок" 
                             Margin="4"/>

                    <Button Grid.Column="4" 
                            Command="{Binding AddCommand}" 
                            Content="Добавить" 
                            Style="{StaticResource PrimaryButton}" 
                            Margin="4,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DataGrid (Row 2) -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Items}" 
                  SelectedItem="{Binding SelectedItem}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="False" 
                  CanUserAddRows="False"
                  materialDesign:DataGridAssist.CellPadding="13 8 8 8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                  MinRowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Метод" Binding="{Binding MethodName}" IsReadOnly="True" Width="120"/>
                <DataGridTextColumn Header="Заголовок" Binding="{Binding TheoryTitle}" Width="200"/>

                <DataGridTemplateColumn Header="Содержание" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TheoryContent}" 
                                       TextWrapping="Wrap" 
                                       VerticalAlignment="Center"
                                       MaxHeight="60"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding TheoryContent, UpdateSourceTrigger=LostFocus}" 
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Порядок" Binding="{Binding SortOrder}" Width="80"/>
                <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="150"/>
                <DataGridTextColumn Header="Обновлён" Binding="{Binding UpdatedAt, StringFormat='dd.MM.yyyy HH:mm'}" IsReadOnly="True" Width="150"/>

                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding Id}" 
                                    Content="Удалить" 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="Red"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка Сохранить (Row 3) -->
        <Button Grid.Row="3" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Center" 
                Command="{Binding SaveCommand}" 
                Content="Сохранить изменения" 
                Style="{StaticResource PrimaryButton}" 
                Margin="0,16,0,0" 
                Width="200"/>
    </Grid>
</UserControl>